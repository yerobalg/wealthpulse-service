ENV=development

# Database (SQLite file — created automatically; back up by copying it)
DB_PATH=./data/wealthpulse.db

# Database Connection Pool
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MINUTE=30
DB_CONN_MAX_IDLE_TIME_MINUTE=5

# Database encryption (used by the GORM field-encryption helper)
DB_ENCRYPTION_KEY=

# Single seeded superuser (created idempotently at startup from the env hash).
# Generate the bcrypt hash with `make gen-password password=yourpassword`.
# Wrap the hash in single quotes so godotenv keeps the '$' literal (no escaping).
SUPERUSER_USERNAME=
SUPERUSER_PASSWORD_HASH='$2a$08$replace-with-make-gen-password-output'
SUPERUSER_NAME=

# Password
PASSWORD_SALT_ROUND=8

# JWT
JWT_EXPIRED_TIME_SEC=3600
JWT_SECRET_KEY=

# App
APP_HOST=localhost
APP_PORT=8080

# Market-data providers
COINGECKO_API_KEY=
COINGECKO_BASE_URL=
YAHOO_FINANCE_BASE_URL=
METALPRICE_API_KEY=
EXCHANGERATE_API_KEY=

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Scheduler & targets
PRICE_FETCH_INTERVAL=5
SNAPSHOT_INTERVAL=30
PREFERRED_CURRENCY=IDR
YOY_TARGET=15
