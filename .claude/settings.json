{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // \"\"' | grep -q 'src/usecase/' && gocognit -over 15 ./src/usecase/ 2>/dev/null || true",
            "statusMessage": "Checking cognitive complexity..."
          }
        ]
      }
    ]
  }
}
